{
  "uid": "bank-http-jvm",
  "title": "Bank — HTTP & JVM",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "10s",
  "panels": [
    { "id": 1, "type": "timeseries", "title": "RPS by service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum by (service) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{service}}" } ] },
    { "id": 2, "type": "timeseries", "title": "5xx rate by service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum by (service) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))", "legendFormat": "{{service}}" } ] },
    { "id": 3, "type": "timeseries", "title": "4xx rate by service",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum by (service) (rate(http_server_requests_seconds_count{status=~\"4..\"}[1m]))", "legendFormat": "{{service}}" } ] },
    { "id": 4, "type": "timeseries", "title": "p95 latency (s) by service",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, service) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "{{service}}" } ] },
    { "id": 5, "type": "timeseries", "title": "JVM heap used (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum by (service) (jvm_memory_used_bytes{area=\"heap\"})", "legendFormat": "{{service}}" } ] },
    { "id": 6, "type": "timeseries", "title": "Process CPU usage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "process_cpu_usage", "legendFormat": "{{service}}" } ] }
  ]
}
